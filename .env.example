# Database Configuration
# For local development, use: file:local.db
# For production with Turso, get your URL and auth token from https://turso.tech
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# JWT Secret - IMPORTANT: Change this to a secure random string in production!
# Generate a secure secret with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production-USE-SECURE-RANDOM-STRING
